---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  /** Override the default OG image (e.g. per blog post) — path relative to site root. */
  image?: string;
}

const {
  title,
  description = 'grimbergIT — consultancy and training by Joel Grimberg.',
  image,
} = Astro.props;
const site = Astro.site ?? new URL('https://grimbergit.nl');
const canonical = new URL(Astro.url.pathname, site).toString();
const ogImage = new URL(image ?? '/og.jpg', site).toString();
---

<!doctype html>
<html lang="en" data-theme="serene">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link
      rel="preload"
      href="/fonts/JetBrainsMono-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <title>{title}</title>

    {/* Open Graph — social sharing previews */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="grimbergIT" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:alt" content="Joel Grimberg — grimbergIT" />

    {/* Twitter card — LinkedIn, Slack, and many others read these too */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Joel Grimberg — grimbergIT" />
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          if (stored === 'nerd' || stored === 'serene') {
            document.documentElement.setAttribute('data-theme', stored);
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <div class="site">
      <Header />
      <main class="site-main">
        <div class="container">
          <slot />
        </div>
      </main>
      <Footer />
    </div>
  </body>
</html>
